    "d": "l2", "t": "l2", "m": "l2",
    "w": "l1", "s": "l1", "c": "l1",
    "z": "l1", "g": "l1", "v": "l1",
    "'": "r1", "y": "r1", "del": "r1",
    "f": "r1", "h": "r1", "k": "r1",
    "o": "r2", "a": "r2", "p": "r2",
    "u": "r3", "e": "r3", ".": "r3",
