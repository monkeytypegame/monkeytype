{
  "name": "@monkeytype/webgpt-runtime",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "dev": "tsup-node --watch",
    "build": "npm run madge && tsup-node && node ./scripts/copy-assets.mjs",
    "test": "vitest run",
    "madge": " madge --circular --extensions ts ./src",
    "ts-check": "tsc --noEmit",
    "lint": "oxlint . --type-aware --type-check",
    "lint-fast": "oxlint ."
  },
  "devDependencies": {
    "@monkeytype/tsup-config": "workspace:*",
    "@monkeytype/typescript-config": "workspace:*",
    "madge": "8.0.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.18.1",
    "tsup": "8.4.0",
    "typescript": "6.0.2",
    "vitest": "4.1.0"
  }
}
